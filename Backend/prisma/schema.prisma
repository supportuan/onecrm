generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------
enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSED
  CONVERTED
  LOST
}

enum LeadRating {
  HOT
  WARM
  COLD
  MAYBE
}

enum CampaignType {
  EMAIL
  SMS
  WHATSAPP
  SOCIAL_MEDIA
  PPC
  GOOGLE_ADS
  CONTENT
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum AutomationStatus {
  ACTIVE
  PAUSED
  DRAFT
}

enum LandingPageType {
  COUNTRY
  COURSE
  INTAKE
  CAMPAIGN
  GUIDE
  EVENT
  FORM
  APPLICATION
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  SMS
  WHATSAPP
  MEETING
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum ApplicationStage {
  DRAFT
  DOCUMENTS_PENDING
  SUBMITTED
  UNDER_REVIEW
  OFFER_RECEIVED
  OFFER_ACCEPTED
  OFFER_REJECTED
  VISA_PROCESS
  ENROLLED
}

enum DocumentStatus {
  PENDING
  UPLOADED
  VERIFIED
  REJECTED
}

enum OfferDecisionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum VisaStatus {
  NOT_STARTED
  DOCUMENTS_GATHERING
  APPLIED
  INTERVIEW_SCHEDULED
  APPROVED
  REJECTED
}

enum UserRole {
  SUPER_ADMIN
  GLOBAL_ADMIN
  HR
  COUNSELLOR
  MARKETING_MANAGER
  TELECALLER
  AGENCY_FREELANCER
  STUDENT
  AGENT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

// -----------------------------------------------------------------------------
// Multi-tenant foundation. Every tenant-scoped row carries `tenantId`.
// SUPER_ADMIN users have tenantId = null and operate cross-tenant.
// -----------------------------------------------------------------------------
model Tenant {
  id        Int          @id @default(autoincrement())
  name      String
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users           User[]
  rolePermissions RolePermission[]
  modules         TenantModule[]
  audits          SuperAdminAudit[]

  hrEmployees              HrEmployee[]
  hrAttendanceDevices      HrAttendanceDevice[]
  hrAttendanceSetting      HrAttendanceSetting?
  hrAttendanceRecords      HrAttendanceRecord[]
  hrRegularizations        HrRegularization[]
  hrNetworkWhitelists      HrNetworkWhitelist[]
  hrLeavePlans             HrLeavePlan[]
  hrLeaveTypes             HrLeaveType[]
  hrLeaveDefinitions       HrLeaveDefinition[]
  hrLeavePlanAssignments   HrLeavePlanAssignment[]
  hrLeaveRequests          HrLeaveRequest[]
  hrHolidays               HrHoliday[]
  hrJobPostings            HrJobPosting[]
  hrKpiDefinitions         HrKpiDefinition[]
  hrProcessingMetrics      HrProcessingMetric[]
  hrMarketingPerformances  HrMarketingPerformance[]
  hrCounsellorPerformances HrCounsellorPerformance[]
  hrPerformanceReviews     HrPerformanceReview[]
}

// Per-tenant module enablement. If a row is missing, the module is OFF.
// Super admin manages these from the tenant detail page.
model TenantModule {
  tenantId  Int
  moduleKey String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, moduleKey])
  @@index([tenantId])
}

enum AgencyPartnerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum HrAccessRole {
  EMPLOYEE
  SUPER_ADMIN
  HR_MANAGER
  PAYROLL_ADMIN
}

enum HrDeviceStatus {
  online
  offline
}

enum HrAttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

enum HrRegularizationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HrLeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum HrPayslipStatus {
  DRAFT
  PAID
}

enum HrOnboardingCategory {
  DOCUMENTS
  ACCESS
  TRAINING
}

enum HrOnboardingItemStatus {
  PENDING
  COMPLETED
}

enum HrOnboardingChecklistStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum HrOfferLetterStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum HrInterviewType {
  IN_PERSON
  VIRTUAL
  PHONE
}

enum HrInterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum HrJobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum HrJobStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
}

enum HrCandidateStatus {
  ACTIVE
  REJECTED
  HIRED
  WITHDRAWN
}

enum HrKpiFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum HrReviewStatus {
  SELF_REVIEW
  MANAGER_REVIEW
  CALIBRATED
  COMPLETED
}

// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------

model LeadSource {
  id          Int      @id @default(autoincrement())
  name        String
  sourceType  String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leads Lead[]
}

model Lead {
  id                    Int        @id @default(autoincrement())
  fullName              String
  email                 String
  phone                 String?
  country               String?
  preferredCountry      String?
  preferredCourse       String?
  sourceId              Int?
  assignedCounsellorId  Int?
  assignedById          Int?
  status                LeadStatus @default(NEW)
  rating                LeadRating @default(WARM)
  remark                String?
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?
  utmTerm               String?
  utmContent            String?
  studentUserId         Int?
  isStudentLoginCreated Boolean    @default(false)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  externalCampaignId String?
  platform           String?
  launchDetails      Json?

  source             LeadSource?      @relation(fields: [sourceId], references: [id])
  assignedCounsellor User?            @relation("LeadCounsellor", fields: [assignedCounsellorId], references: [id])
  assignedBy         User?            @relation("LeadAssignor", fields: [assignedById], references: [id])
  studentUser        User?            @relation("LeadStudentUser", fields: [studentUserId], references: [id])
  activities         LeadActivity[]
  campaigns          CampaignLead[]
  convertedStudent   Student?         @relation("LeadConvertedStudent")
  agencyReferrals    AgencyReferral[]
}

model LeadActivity {
  id           Int          @id @default(autoincrement())
  leadId       Int
  actorId      Int?
  activityType ActivityType
  comment      String?
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Campaign {
  id             Int            @id @default(autoincrement())
  name           String
  type           CampaignType
  budget         Float?
  spent          Float?         @default(0)
  startDate      DateTime?
  endDate        DateTime?
  status         CampaignStatus @default(DRAFT)
  targetAudience String?
  description    String?
  externalLeadId String?
  audienceType   String         @default("ALL")

  externalCampaignId String?
  platform           String?
  launchDetails      Json?
  emailContent       Json?
  metaAdId           String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  leads      CampaignLead[]
  launchLogs CampaignLaunchLog[]
}

model CampaignLead {
  id         Int      @id @default(autoincrement())
  campaignId Int
  leadId     Int
  status     String?
  engagement String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model MarketingAutomation {
  id               Int                   @id @default(autoincrement())
  workflowName     String
  trigger          String
  action           String
  status           AutomationStatus      @default(DRAFT)
  emailsSent       Int                   @default(0)
  whatsappMessages Int                   @default(0)
  smsSent          Int                   @default(0)
  leadsAutomated   Int                   @default(0)
  engagementRate   Float                 @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deletedAt        DateTime?
  executions       AutomationExecution[]
}

model AutomationExecution {
  id             Int                 @id @default(autoincrement())
  automationId   Int
  executionDate  DateTime            @default(now())
  totalProcessed Int                 @default(0)
  totalSuccess   Int                 @default(0)
  totalFailed    Int                 @default(0)
  createdAt      DateTime            @default(now())
  automation     MarketingAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model LandingPage {
  id             Int             @id @default(autoincrement())
  title          String
  slug           String          @unique
  type           LandingPageType
  country        String?
  course         String?
  visits         Int             @default(0)
  leads          Int             @default(0)
  conversionRate Float           @default(0)
  seoTitle       String?
  seoDescription String?
  content        String?
  formId         String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  forms      MarketingForm[]
  pageVisits LandingPageVisit[]
}

model MarketingForm {
  id               Int      @id @default(autoincrement())
  formName         String
  formType         String
  totalSubmissions Int      @default(0)
  conversionRate   Float    @default(0)
  landingPageId    Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  landingPage LandingPage? @relation(fields: [landingPageId], references: [id], onDelete: SetNull)
}

model LandingPageVisit {
  id            Int      @id @default(autoincrement())
  landingPageId Int
  visitorIp     String?
  source        String?
  visitedAt     DateTime @default(now())

  landingPage LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
}

model MarketingMetric {
  id          Int      @id @default(autoincrement())
  metricKey   String
  metricValue Float
  trend       String?
  period      String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

model MarketingPerformance {
  id          Int      @id @default(autoincrement())
  day         String
  opens       Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  createdAt   DateTime @default(now())
}

model MarketingChannelAnalytics {
  id               Int      @id @default(autoincrement())
  channelName      String
  percentage       Float
  totalLeads       Int      @default(0)
  totalConversions Int      @default(0)
  createdAt        DateTime @default(now())
}

model AgencyFunnelAnalytics {
  id          Int      @id @default(autoincrement())
  funnelName  String
  funnelValue Float
  createdAt   DateTime @default(now())
}

model AnalyticsLog {
  id          Int      @id @default(autoincrement())
  eventType   String
  metricKey   String
  metricValue Float
  metadata    Json?
  createdAt   DateTime @default(now())
}

model IntakeTrend {
  id           Int      @id @default(autoincrement())
  month        String
  applications Int
  enrollments  Int
  revenue      Float
  createdAt    DateTime @default(now())
}

model StudentFunnelStage {
  id         Int      @id @default(autoincrement())
  stage      String
  count      Int
  conversion String
  createdAt  DateTime @default(now())
}

model AgencyFunnelStage {
  id         Int      @id @default(autoincrement())
  stage      String
  count      Int
  conversion String
  createdAt  DateTime @default(now())
}

model User {
  id                 Int       @id @default(autoincrement())
  tenantId           Int?
  fullName           String
  email              String    @unique
  phone              String?
  passwordHash       String
  role               UserRole
  roleLabel          String?
  permissionRole     String?
  isActive           Boolean   @default(true)
  isApproved         Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  policyAcceptedAt DateTime?
  agencyDetails      Json?
  moduleAccess       Json?
  counsellorId       Int?
  lastLogin          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant                  Tenant?                 @relation(fields: [tenantId], references: [id])
  counsellor              User?                   @relation("StudentCounsellor", fields: [counsellorId], references: [id])
  students                User[]                  @relation("StudentCounsellor")
  assignedLeads           Lead[]                  @relation("LeadCounsellor")
  assignedByLeads         Lead[]                  @relation("LeadAssignor")
  studentLeads            Lead[]                  @relation("LeadStudentUser")
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  hrEmployee              HrEmployee?
  notifications           Notification[]          @relation("UserNotifications")
  studentProfile          Student?                @relation("StudentUser")
  studentsAsContact       Student[]               @relation("StudentContact")
  applicationsAssigned    Application[]           @relation("ApplicationAssignee")
  applicationStageChanges ApplicationStageEvent[] @relation("StageChangedBy")
  agencyPartner           AgencyPartner?
}

model Notification {
  id          Int                 @id @default(autoincrement())
  recipientId Int
  templateKey String
  channel     NotificationChannel
  status      NotificationStatus  @default(PENDING)
  title       String
  body        String
  link        String?
  vars        Json?
  error       String?
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime            @default(now())

  recipient User @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, status])
  @@index([recipientId, createdAt])
}

// -----------------------------------------------------------------------------
// CRM Settings — master data (Student CRM scope)
// -----------------------------------------------------------------------------

model Country {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  symbol    String?
  currency  String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  students          Student[]
  universities      University[]
  faqs              Faq[]
  countryChecklists CountryChecklist[]
}

model StudyIndustry {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  subIndustries StudySubIndustry[]
  studyAreas    StudyArea[]
  students      Student[]
}

model StudySubIndustry {
  id         Int       @id @default(autoincrement())
  name       String
  industryId Int
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  industry   StudyIndustry @relation(fields: [industryId], references: [id], onDelete: Cascade)
  studyAreas StudyArea[]
  students   Student[]

  @@unique([industryId, name])
}

model StudyArea {
  id            Int       @id @default(autoincrement())
  name          String
  industryId    Int
  subIndustryId Int?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  industry    StudyIndustry     @relation(fields: [industryId], references: [id], onDelete: Cascade)
  subIndustry StudySubIndustry? @relation(fields: [subIndustryId], references: [id], onDelete: SetNull)
  students    Student[]

  @@unique([industryId, name])
}

model University {
  id         Int       @id @default(autoincrement())
  externalId Int?      @unique
  name       String
  countryId  Int
  city       String?
  location   String?
  logo       String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  country             Country             @relation(fields: [countryId], references: [id], onDelete: Cascade)
  studentUniversities StudentUniversity[]
  courses             Course[]

  @@unique([countryId, name])
}

model Course {
  id             Int       @id @default(autoincrement())
  externalId     Int?      @unique
  name           String
  universityId   Int
  level          String?
  intakes        String?
  applicationFee String?
  tuitionFee     String?
  duration       String?
  ielts          String?
  toefl          String?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId])
  @@index([name])
}

// -----------------------------------------------------------------------------
// Student CRM — Applications module
// -----------------------------------------------------------------------------

enum ApplicationProcessStage {
  GATHERING_CHECKLIST
  UNIVERSITY_APPLICATION
  FINANCIAL_EVIDENCE
  AFTER_I20
  PRE_CAS_PROCESS
  VISA_APPLICATION
  PRE_DEPARTURE
  ON_ARRIVAL
  PRE_REQUISITE
}

model Student {
  id                  Int                     @id @default(autoincrement())
  userId              Int?                    @unique
  firstName           String?
  lastName            String?
  fullName            String
  email               String                  @unique
  phone               String?
  dob                 DateTime?
  nationality         String?
  preferredCountry    String?
  level               String?
  countryId           Int?
  industryId          Int?
  subIndustryId       Int?
  studyAreaId         Int?
  intakeMonth         String?
  intakeYear          String?
  studyMode           String?
  studyDuration       String?
  studyBudget         String?
  studyAttendanceType String?
  typeOfDegree        String?
  workExperience      String?
  recLevelAcademic    String?
  recGradeAchieved    String?
  preStudyLoc         String?
  educationDetails    Json?
  asstExamSections    Json?
  academicHistory     Json?
  ieltsScore          Float?
  toeflScore          Float?
  greScore            Float?
  gmatScore           Float?
  contactId           Int?
  processStage        ApplicationProcessStage @default(GATHERING_CHECKLIST)
  stageTotalTask      Int                     @default(0)
  stageCompletedTask  Int                     @default(0)
  totalCheckList      Int                     @default(0)
  completedCheckList  Int                     @default(0)
  stepsTimestamp      Json?
  status              String                  @default("CURRENT")
  isEnrolled          Boolean                 @default(false)
  source              String?
  sourceLeadId        Int?                    @unique
  notes               String?
  deletedAt           DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  user              User?               @relation("StudentUser", fields: [userId], references: [id])
  contact           User?               @relation("StudentContact", fields: [contactId], references: [id])
  sourceLead        Lead?               @relation("LeadConvertedStudent", fields: [sourceLeadId], references: [id])
  country           Country?            @relation(fields: [countryId], references: [id])
  industry          StudyIndustry?      @relation(fields: [industryId], references: [id])
  subIndustry       StudySubIndustry?   @relation(fields: [subIndustryId], references: [id])
  studyArea         StudyArea?          @relation(fields: [studyAreaId], references: [id])
  applications      Application[]
  universities      StudentUniversity[]
  checklists        StudentChecklist[]
  feedbacks         Feedback[]
  chats             Chat[]
  agencyReferrals   AgencyReferral[]
  agencyCommissions AgencyCommission[]

  @@index([email])
  @@index([contactId])
  @@index([deletedAt])
  @@index([source])
}

model StudentUniversity {
  id            Int      @id @default(autoincrement())
  studentId     Int
  universityId  Int
  value         String?
  isSelected    Boolean  @default(false)
  status        String   @default("Application Processing")
  appliedIntake String?
  offerIntake   String?
  courseLink    String?
  defer         Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([studentId, universityId])
}

model CheckList {
  id          Int                     @id @default(autoincrement())
  name        String
  stage       ApplicationProcessStage
  description String?
  required    Boolean                 @default(true)
  deletedAt   DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  countryLinks CountryChecklist[]
  studentItems StudentChecklist[]
}

model CountryChecklist {
  id          Int      @id @default(autoincrement())
  countryId   Int
  checkListId Int
  createdAt   DateTime @default(now())

  country   Country   @relation(fields: [countryId], references: [id], onDelete: Cascade)
  checkList CheckList @relation(fields: [checkListId], references: [id], onDelete: Cascade)

  @@unique([countryId, checkListId])
}

model StudentChecklist {
  id          Int      @id @default(autoincrement())
  studentId   Int
  checkListId Int
  value       String?
  linkUrl     String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  checkList CheckList @relation(fields: [checkListId], references: [id], onDelete: Cascade)

  @@unique([studentId, checkListId])
}

model Resource {
  id          Int       @id @default(autoincrement())
  name        String
  url         String?
  slug        String    @unique
  parentId    Int?
  userType    Int       @default(1)
  folderImage String?
  isFolder    Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent   Resource?  @relation("ResourceTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Resource[] @relation("ResourceTree")
}

model Faq {
  id        Int       @id @default(autoincrement())
  countryId Int?
  query     String    @db.VarChar(200)
  solution  String    @db.VarChar(500)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  country Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)
}

model AdditionalService {
  id              Int       @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String
  phone           String?
  alternatePhone  String?
  dob             String?
  gender          String?
  passportNo      String?
  presentStatus   String?
  countryId       Int?
  selectedService String?
  images          Json?
  notes           String?
  callBackTime    DateTime?
  status          String    @default("NOT_CONTACTED")
  isContacted     Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Chat {
  id          Int      @id @default(autoincrement())
  studentId   Int
  authorId    Int
  message     String   @db.Text
  attachments Json?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Feedback {
  id        Int      @id @default(autoincrement())
  studentId Int      @unique
  rating    Int
  feedback  String?  @db.VarChar(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Application {
  id              Int              @id @default(autoincrement())
  applicationCode String           @unique
  studentId       Int
  country         String
  university      String
  course          String
  intake          String?
  stage           ApplicationStage @default(DRAFT)
  assignedToId    Int?
  deadline        DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  student           Student                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignedTo        User?                   @relation("ApplicationAssignee", fields: [assignedToId], references: [id])
  stageEvents       ApplicationStageEvent[]
  documents         ApplicationDocument[]
  offerLetter       OfferLetter?
  visaTracking      VisaTracking?
  agencyReferrals   AgencyReferral[]
  agencyCommissions AgencyCommission[]

  @@index([studentId])
  @@index([stage])
  @@index([assignedToId])
}

// -----------------------------------------------------------------------------
// Agency CRM
// -----------------------------------------------------------------------------

model AgencyPartner {
  id             Int                 @id @default(autoincrement())
  userId         Int                 @unique
  agencyName     String
  agencyCode     String              @unique
  contactPerson  String?
  email          String?
  phone          String?
  address        String?
  city           String?
  country        String?
  commissionRate Float               @default(10)
  status         AgencyPartnerStatus @default(PENDING)
  branding       Json?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals   AgencyReferral[]
  commissions AgencyCommission[]

  @@index([status])
  @@index([agencyCode])
}

model AgencyReferral {
  id              Int      @id @default(autoincrement())
  agencyPartnerId Int
  leadId          Int?
  studentId       Int?
  applicationId   Int?
  referralCode    String?
  status          String   @default("REFERRED")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agencyPartner AgencyPartner @relation(fields: [agencyPartnerId], references: [id], onDelete: Cascade)
  lead          Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  student       Student?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  application   Application?  @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([agencyPartnerId])
  @@index([leadId])
  @@index([studentId])
  @@index([applicationId])
}

model AgencyCommission {
  id              Int              @id @default(autoincrement())
  agencyPartnerId Int
  studentId       Int?
  applicationId   Int?
  amount          Float
  currency        String           @default("GBP")
  status          CommissionStatus @default(PENDING)
  period          String?
  description     String?
  paidAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  agencyPartner AgencyPartner @relation(fields: [agencyPartnerId], references: [id], onDelete: Cascade)
  student       Student?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  application   Application?  @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([agencyPartnerId])
  @@index([status])
}

model ApplicationStageEvent {
  id            Int               @id @default(autoincrement())
  applicationId Int
  fromStage     ApplicationStage?
  toStage       ApplicationStage
  changedById   Int?
  notes         String?
  createdAt     DateTime          @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  changedBy   User?       @relation("StageChangedBy", fields: [changedById], references: [id])

  @@index([applicationId, createdAt])
}

model ApplicationDocument {
  id            Int            @id @default(autoincrement())
  applicationId Int
  name          String
  required      Boolean        @default(true)
  filename      String?
  fileUrl       String?
  status        DocumentStatus @default(PENDING)
  uploadedAt    DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, status])
}

model OfferLetter {
  id               Int                 @id @default(autoincrement())
  applicationId    Int                 @unique
  fileUrl          String?
  filename         String?
  receivedAt       DateTime?
  conditional      Boolean             @default(false)
  decisionDeadline DateTime?
  studentDecision  OfferDecisionStatus @default(PENDING)
  decisionAt       DateTime?
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model VisaTracking {
  id              Int        @id @default(autoincrement())
  applicationId   Int        @unique
  country         String
  status          VisaStatus @default(NOT_STARTED)
  appointmentDate DateTime?
  decisionDate    DateTime?
  documents       Json?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model DocumentChecklistTemplate {
  id         Int      @id @default(autoincrement())
  country    String
  university String?
  documents  Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([country, university])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// HR Module
// -----------------------------------------------------------------------------

model HrEmployee {
  id           Int          @id @default(autoincrement())
  tenantId     Int?
  name         String
  employeeCode String       @unique
  email        String       @unique
  accessRole   HrAccessRole @default(EMPLOYEE)
  department   String?
  designation  String?
  phone        String?
  biometricId  String?
  location     String?
  userId       Int?         @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant               Tenant?                 @relation(fields: [tenantId], references: [id])
  user                 User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  attendanceRecords    HrAttendanceRecord[]
  regularizations      HrRegularization[]
  leavePlanAssignments HrLeavePlanAssignment[]
  leaveRequests        HrLeaveRequest[]
  salaryStructure      HrSalaryStructure?
  payslips             HrPayslip[]
  payrollDeductions    HrPayrollDeduction[]
  onboardingChecklists HrOnboardingChecklist[]
  performanceReviews   HrPerformanceReview[]

  @@index([tenantId])
}

model HrAttendanceDevice {
  id         Int            @id @default(autoincrement())
  tenantId   Int?
  deviceId   String
  deviceName String
  deviceIp   String
  status     HrDeviceStatus @default(online)
  lastSync   DateTime       @default(now())
  settings   Json           @default("{}")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant            Tenant?              @relation(fields: [tenantId], references: [id])
  attendanceRecords HrAttendanceRecord[]

  @@index([tenantId])
}

model HrNetworkWhitelist {
  id               Int      @id @default(autoincrement())
  tenantId         Int?
  ipAddressOrRange String
  label            String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model HrAttendanceSetting {
  tenantId           Int      @id
  attendanceMode     String   @default("biometric")
  enableIpValidation Boolean  @default(true)
  updatedAt          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model HrAttendanceRecord {
  id         Int                @id @default(autoincrement())
  tenantId   Int?
  employeeId Int
  date       String
  checkIn    DateTime?
  checkOut   DateTime?
  status     HrAttendanceStatus
  deviceRef  String?
  deviceDbId Int?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  tenant   Tenant?             @relation(fields: [tenantId], references: [id])
  employee HrEmployee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  device   HrAttendanceDevice? @relation(fields: [deviceDbId], references: [id], onDelete: SetNull)

  @@index([employeeId, date])
  @@index([tenantId])
}

model HrRegularization {
  id              Int                    @id @default(autoincrement())
  tenantId        Int?
  employeeId      Int
  name            String
  date            String
  type            String
  time            String
  reason          String
  status          HrRegularizationStatus @default(PENDING)
  approverRemarks String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  tenant   Tenant?    @relation(fields: [tenantId], references: [id])
  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model HrLeavePlan {
  id          Int      @id @default(autoincrement())
  tenantId    Int?
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant?                 @relation(fields: [tenantId], references: [id])
  definitions HrLeaveDefinition[]
  assignments HrLeavePlanAssignment[]

  @@index([tenantId])
}

model HrLeaveType {
  id        Int      @id @default(autoincrement())
  tenantId  Int?
  name      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant?             @relation(fields: [tenantId], references: [id])
  definitions HrLeaveDefinition[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model HrLeaveDefinition {
  id           Int      @id @default(autoincrement())
  tenantId     Int?
  planId       Int
  leaveTypeId  Int
  name         String
  annualQuota  Int
  carryForward Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant?     @relation(fields: [tenantId], references: [id])
  plan      HrLeavePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  leaveType HrLeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([planId, leaveTypeId])
  @@index([tenantId])
}

model HrLeavePlanAssignment {
  id         Int  @id @default(autoincrement())
  tenantId   Int?
  planId     Int
  employeeId Int

  tenant   Tenant?     @relation(fields: [tenantId], references: [id])
  plan     HrLeavePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  employee HrEmployee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([planId, employeeId])
  @@index([tenantId])
}

model HrHoliday {
  id           Int      @id @default(autoincrement())
  tenantId     Int?
  name         String
  date         String
  isRestricted Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model HrLeaveRequest {
  id            Int                  @id @default(autoincrement())
  tenantId      Int?
  employeeId    Int
  leaveTypeName String
  fromDate      String
  toDate        String
  days          Float
  reason        String?
  status        HrLeaveRequestStatus @default(PENDING)
  reviewerNote  String?
  reviewedAt    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  tenant   Tenant?    @relation(fields: [tenantId], references: [id])
  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, status])
  @@index([status, createdAt])
  @@index([tenantId])
}

model HrSalaryStructure {
  id          Int      @id @default(autoincrement())
  employeeId  Int      @unique
  basicSalary Float
  allowances  Float
  deductions  Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model HrPayslip {
  id          Int             @id @default(autoincrement())
  employeeId  Int
  name        String
  month       Int
  year        Int
  basicSalary Float
  allowances  Float
  deductions  Float
  netSalary   Float
  status      HrPayslipStatus @default(DRAFT)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
}

model HrPayrollDeduction {
  id              Int      @id @default(autoincrement())
  employeeId      Int
  month           Int
  year            Int
  leaveDays       Int      @default(0)
  leaveDeduction  Float    @default(0)
  taxAmount       Float    @default(0)
  otherDeductions Float    @default(0)
  totalDeductions Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
}

model HrOnboardingChecklist {
  id           Int                         @id @default(autoincrement())
  employeeId   Int
  employeeName String
  startDate    String
  status       HrOnboardingChecklistStatus @default(PENDING)
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  employee HrEmployee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  items    HrOnboardingItem[]
}

model HrOnboardingItem {
  id          Int                    @id @default(autoincrement())
  checklistId Int
  category    HrOnboardingCategory
  title       String
  description String?
  status      HrOnboardingItemStatus @default(PENDING)
  completedAt DateTime?
  completedBy String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  checklist HrOnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model HrJobPosting {
  id            Int         @id @default(autoincrement())
  tenantId      Int?
  title         String
  department    String
  location      String
  type          HrJobType
  description   String
  requirements  String
  salaryRange   String
  status        HrJobStatus @default(DRAFT)
  hiringManager String
  postedAt      String?
  closingDate   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant     Tenant?       @relation(fields: [tenantId], references: [id])
  candidates HrCandidate[]

  @@index([tenantId])
}

model HrCandidate {
  id           Int               @id @default(autoincrement())
  jobId        Int
  name         String
  email        String
  phone        String
  resumeUrl    String?
  currentStage String
  status       HrCandidateStatus @default(ACTIVE)
  appliedAt    String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  job          HrJobPosting    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  offerLetters HrOfferLetter[]
  interviews   HrInterview[]
}

model HrOfferLetter {
  id             Int                 @id @default(autoincrement())
  candidateId    Int
  candidateName  String
  candidateEmail String
  jobTitle       String
  department     String
  offeredSalary  Float
  joiningDate    String
  expiryDate     String
  status         HrOfferLetterStatus @default(DRAFT)
  policyTemplate String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  candidate HrCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model HrInterview {
  id            Int               @id @default(autoincrement())
  candidateId   Int
  candidateName String
  jobTitle      String
  round         String
  type          HrInterviewType
  scheduledAt   DateTime
  duration      Int
  interviewers  Json
  meetingLink   String?
  status        HrInterviewStatus @default(SCHEDULED)
  feedback      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  candidate HrCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model HrProcessingMetric {
  id                    Int      @id @default(autoincrement())
  tenantId              Int?
  period                String
  totalApplications     Int
  processedApplications Int
  accurateApplications  Int
  avgTurnaroundDays     Float
  reviewsCompleted      Int
  pendingReviews        Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, period])
  @@index([tenantId])
}

model HrKpiDefinition {
  id          Int            @id @default(autoincrement())
  tenantId    Int?
  role        String
  name        String
  description String?
  target      Float
  unit        String
  frequency   HrKpiFrequency @default(MONTHLY)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant  Tenant?       @relation(fields: [tenantId], references: [id])
  metrics HrKpiMetric[]

  @@index([tenantId])
}

model HrKpiMetric {
  id          Int      @id @default(autoincrement())
  kpiId       Int
  userId      String?
  userRole    String
  period      String
  actualValue Float
  targetValue Float
  notes       String?
  recordedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kpiDefinition HrKpiDefinition @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([kpiId, period, userId])
}

model HrMarketingPerformance {
  id             Int      @id @default(autoincrement())
  tenantId       Int?
  period         String
  leadsGenerated Int
  costPerLead    Float
  totalBudget    Float
  channel        String
  conversions    Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model HrCounsellorPerformance {
  id             Int      @id @default(autoincrement())
  tenantId       Int?
  counsellorId   String
  counsellorName String
  period         String
  leadsHandled   Int
  conversions    Int
  revenue        Float
  conversionRate Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([counsellorId, period])
  @@index([tenantId])
}

model HrPerformanceReview {
  id           Int            @id @default(autoincrement())
  tenantId     Int?
  employeeId   Int?
  name         String
  employeeCode String
  department   String
  cycle        String
  manager      String
  rating       Float          @default(0)
  status       HrReviewStatus @default(SELF_REVIEW)
  reviewDate   String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant   Tenant?     @relation(fields: [tenantId], references: [id])
  employee HrEmployee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

// -----------------------------------------------------------------------------
// RBAC: dynamic role -> permission mapping (editable live from admin settings)
// -----------------------------------------------------------------------------
model RolePermission {
  id          Int      @id @default(autoincrement())
  tenantId    Int?
  role        String
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, role])
}

model Permission {
  id        Int      @id @default(autoincrement())
  module    String
  option    String
  action    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([module, option, action])
}

model CampaignLaunchLog {
  id          Int      @id @default(autoincrement())
  campaignId  Int
  launchedBy  Int?
  launchedAt  DateTime @default(now())
  status      String
  details     Json?
  createdAt   DateTime @default(now())

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([createdAt])
}

// Append-only log of write actions taken from the Super Admin UI.
// `actorId` is the super-admin user; `targetTenantId` is the affected tenant.
// `payload` captures the smallest useful diff (modules array, new email, etc.).
model SuperAdminAudit {
  id             Int      @id @default(autoincrement())
  actorId        Int
  action         String
  targetTenantId Int?
  payload        Json?
  createdAt      DateTime @default(now())

  tenant Tenant? @relation(fields: [targetTenantId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([targetTenantId])
  @@index([action])
  @@index([createdAt])
}

