{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "isolatedModules": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "dist",
    "node_modules"
  ]
}