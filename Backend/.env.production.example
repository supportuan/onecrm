# ===========================================================================
# One CRM — production runtime environment (TEMPLATE)
# Copy to a private prod.env and fill real values. NEVER commit the filled file.
# These are injected into the container at runtime: `docker run --env-file prod.env`
# ===========================================================================

# --- Core ---
# Postgres connection. Encode special chars in the password (e.g. '#' -> %23).
# Add ?sslmode=require if your RDS enforces SSL; ?schema=onecrm to pin a schema.
DATABASE_URL="postgresql://postgres:Applyuninow#2026@database-1.cd0oaiauc0sc.ap-south-1.rds.amazonaws.com:5432/postgres"
JWT_SECRET="generate-a-long-random-secret"

# Service ports inside the container (defaults shown).
BACKEND_PORT=4000
FRONTEND_PORT=3000

# Run `prisma migrate deploy` on container start (true/false).
RUN_MIGRATIONS=true

# --- AWS S3 (file uploads) ---
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_PREFIX=onecrm
AWS_S3_SIGNED_URL_EXPIRES_SECONDS=3600

# Auto-resize/compress photos before S3 / Meta (true/false). PDFs are left unchanged.
UPLOAD_OPTIMIZE=true
UPLOAD_IMAGE_MAX_DIMENSION=1920
UPLOAD_IMAGE_QUALITY=80
# Force disk storage (s3 | local). Leave unset to try S3 then fall back to local if GetObject fails.
# UPLOAD_STORAGE=local


