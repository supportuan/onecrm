# ===========================================================================
# ApplyUniNow — production runtime environment (TEMPLATE)
# Copy to a private prod.env and fill real values. NEVER commit the filled file.
# These are injected into the container at runtime: `docker run --env-file prod.env`
# ===========================================================================

# --- Core ---
# Postgres connection. Encode special chars in the password (e.g. '#' -> %23).
# Add ?sslmode=require if your RDS enforces SSL; ?schema=onecrm to pin a schema.
DATABASE_URL="postgresql://db_user:replace-with-url-encoded-password@db-host.example.com:5432/applyuninow?sslmode=require"
JWT_SECRET="generate-a-long-random-secret"

# Service ports inside the container (defaults shown).
BACKEND_PORT=4000
FRONTEND_PORT=3000

# Public frontend origin used in emails (password reset, student welcome, etc.).
# Required in production — without this, reset links fall back to localhost.
# FRONTEND_URL=https://your-public-domain.com

# Run `prisma migrate deploy` on container start (true/false).
RUN_MIGRATIONS=true

# --- AWS S3 (file uploads) ---
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_PREFIX=applyuninow
AWS_S3_SIGNED_URL_EXPIRES_SECONDS=3600

# Auto-resize/compress photos before S3 / Meta (true/false). PDFs are left unchanged.
UPLOAD_OPTIMIZE=true
UPLOAD_IMAGE_MAX_DIMENSION=1920
UPLOAD_IMAGE_QUALITY=80
# Force disk storage (s3 | local). Leave unset to try S3 then fall back to local if GetObject fails.
# UPLOAD_STORAGE=local
# Optional public origin for local files. Leave unset to use same-origin `/uploads/...`
# (recommended — Next proxies /uploads to the backend). Never use http://localhost here in prod.
# UPLOAD_BASE_URL=https://your-public-domain.com


GOOGLE_ADS_WEBHOOK_KEY=your-google-ads-webhook-secret
META_VERIFY_TOKEN=your-meta-verify-token
META_ACCESS_TOKEN=your-meta-access-token
META_PAGE_ID=your-meta-page-id
META_APP_SECRET=your-meta-app-secret
 
 
# RESEND_API_KEY=your_resend_api_key
# EMAIL_FROM=noreply@yourdomain.com
 
# META_ACCESS_TOKEN=your_meta_access_token
# META_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
 
# # --- OMNICHANNEL COMMUNICATION ---
TWILIO_ACCOUNT_SID="your_twilio_account_sid_here"
TWILIO_AUTH_TOKEN="your_twilio_auth_token_here"
TWILIO_PHONE_NUMBER="+1234567890"
 
# META_WHATSAPP_TOKEN="your-meta-whatsapp-token"
META_PHONE_NUMBER_ID="your-meta-phone-number-id"
WHATSAPP_VERIFY_TOKEN="your-whatsapp-verify-token"
META_WABA_ID="your-meta-waba-id"
 
 
 
# # ---SMTP --------
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-account@example.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM="ApplyUniNow" <your-account@example.com>
# TEST_EMAIL=test-recipient@example.com
 
# # ---SMTP --------
# SMTP_HOST=mail.thefoundrys.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM='"ApplyUniNow" <noreply@example.com>'
 
# --- SMTP (Gmail) ---
# Use a Google App Password — NOT your normal Gmail password.
# Create one: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM="Apply UniNow" <your-account@gmail.com>

# --- HR payroll incentives (counsellor performance-linked variable pay) ---
HR_DEFAULT_ENROLLMENT_REVENUE=25000
HR_INCENTIVE_PER_ENROLLMENT=5000
HR_INCENTIVE_REVENUE_SHARE=0.02